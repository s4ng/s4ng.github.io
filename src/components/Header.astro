---
const path = Astro.url.pathname;
const isActive = (base: string) =>
  base === '/' ? path === '/' : path.startsWith(base);

const links = [
  { href: '/', label: '블로그', match: '/' },
  { href: '/study', label: '학습기록', match: '/study' },
  { href: '/info', label: '정보', match: '/info' },
];
---

<header class="border-b border-border">
  <nav
    class="mx-auto flex max-w-3xl items-center justify-between px-5 py-4"
  >
    <a href="/" class="font-bold text-fg hover:text-fg">s4ng</a>
    <ul class="flex items-center gap-5 text-sm">
      {
        links.map((l) => (
          <li>
            <a
              href={l.href}
              class:list={[
                'transition-colors',
                isActive(l.match)
                  ? 'text-accent'
                  : 'text-fg-muted hover:text-fg',
              ]}
            >
              {l.label}
            </a>
          </li>
        ))
      }
    </ul>
  </nav>
</header>
