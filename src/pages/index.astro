---
import { getCollection } from 'astro:content';
import Base from '../layouts/Base.astro';
import { formatDate, toSlug } from '../lib/utils';

const posts = (await getCollection('blog')).sort(
  (a, b) => b.data.date.getTime() - a.data.date.getTime()
);

// group by year, preserving descending order
const byYear = new Map<number, typeof posts>();
for (const post of posts) {
  const year = post.data.date.getUTCFullYear();
  if (!byYear.has(year)) byYear.set(year, []);
  byYear.get(year)!.push(post);
}
const years = [...byYear.keys()].sort((a, b) => b - a);
---

<Base title="블로그">
  <h1 class="mb-10 text-2xl font-bold">블로그</h1>

  <div class="space-y-10">
    {
      years.map((year) => (
        <section>
          <h2 class="mb-4 text-xl font-semibold text-fg-muted">{year}</h2>
          <ul class="space-y-1.5">
            {byYear.get(year)!.map((post) => (
              <li class="flex flex-col gap-1 sm:flex-row sm:items-baseline sm:gap-4">
                <time
                  datetime={post.data.date.toISOString()}
                  class="shrink-0 font-mono text-sm text-fg-muted"
                >
                  {formatDate(post.data.date)}
                </time>
                <a
                  href={`/blog/${toSlug(post.id)}/`}
                  class="text-fg hover:text-accent"
                >
                  {post.data.title}
                </a>
              </li>
            ))}
          </ul>
        </section>
      ))
    }
  </div>
</Base>
