---
import Base from './Base.astro';
import { formatDate } from '../lib/utils';

interface Props {
  title: string;
  date?: Date;
  tags?: string[];
  backHref: string;
  backLabel: string;
}

const { title, date, tags = [], backHref, backLabel } = Astro.props;
---

<Base title={title}>
  <a href={backHref} class="text-sm text-fg-muted hover:text-fg"
    >← {backLabel}</a
  >
  <article class="mt-6">
    <header class="mb-8">
      <h1 class="text-3xl font-bold leading-tight text-fg">{title}</h1>
      {
        (date || tags.length > 0) && (
          <div class="mt-3 flex flex-wrap items-center gap-3 text-sm text-fg-muted">
            {date && <time datetime={date.toISOString()}>{formatDate(date)}</time>}
            {tags.map((t) => (
              <span class="rounded bg-bg-elev px-2 py-0.5 text-xs">#{t}</span>
            ))}
          </div>
        )
      }
    </header>
    <div class="prose">
      <slot />
    </div>
  </article>
</Base>

<script>
  const diagrams = document.querySelectorAll<HTMLElement>('pre.mermaid');
  if (diagrams.length > 0) {
    const { default: mermaid } = await import('mermaid');
    mermaid.initialize({
      startOnLoad: false,
      theme: 'dark',
      securityLevel: 'strict',
      fontFamily:
        'ui-sans-serif, system-ui, "Apple SD Gothic Neo", "Malgun Gothic", "Noto Sans KR", sans-serif',
    });
    mermaid.run({ nodes: Array.from(diagrams) });
  }
</script>

<style is:global>
  .prose pre.mermaid {
    background: none !important;
    border: none;
    padding: 0;
    text-align: center;
  }
</style>
